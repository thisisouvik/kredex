# ── Database (NeonDB + Prisma) ────────────────────────────────────────────────
# Get from: https://console.neon.tech → Your Project → Connection Details
# Use the "Pooled connection" URL for DATABASE_URL (pgBouncer)
DATABASE_URL="postgres://neondb_owner:your-password@ep-your-endpoint.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
# Use the "Direct connection" URL for DIRECT_URL (for Prisma migrations)
DIRECT_URL="postgres://neondb_owner:your-password@ep-your-endpoint.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stellar Testnet ───────────────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# ── Soroban RPC ───────────────────────────────────────────────────────────────
# Testnet Soroban RPC endpoint (no API key required for testnet)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Soroban Contract IDs ──────────────────────────────────────────────────────
# Generated when deploying contracts to the Stellar network.
NEXT_PUBLIC_REPUTATION_CONTRACT_ID=
NEXT_PUBLIC_ESCROW_CONTRACT_ID=
NEXT_PUBLIC_LENDING_CONTRACT_ID=
NEXT_PUBLIC_DEFAULT_CONTRACT_ID=

# ── Admin Stellar Address ─────────────────────────────────────────────────────
# Public G... address of the admin account with contract privileges.
NEXT_PUBLIC_ADMIN_ADDRESS=
ADMIN_WALLET_ADDRESS=

# ── Auth & Security ───────────────────────────────────────────────────────────
# Secret for signing JWT session tokens — MUST be a long random string in production
JWT_SECRET=change-me-to-a-very-long-random-secret

# Secret for authorizing cron endpoint calls
CRON_SECRET=change-me-cron-secret

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Reputation NFT Contract ───────────────────────────────────────────────────
NEXT_PUBLIC_REPUTATION_NFT_CONTRACT_ID=

# ── Stellar Disbursement Platform ─────────────────────────────────────────────
# Treasury keypair secret key — used server-side to sign batch disbursement txs.
# NEVER commit this to Git. Set in .env.local only.
ADMIN_SECRET_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PENDING_ROLE_KEY=trustlend_pending_role
